{
  "_comment": "Hook 配置示意，对应 Ch26。timeout_ms 必须设上限。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/check.py",
            "timeout_ms": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/stop_check.py",
            "timeout_ms": 10000
          }
        ]
      }
    ]
  }
}
