# MCP 数据源凭证模板
# 复制为 .env 后填写真实值；.env 不会被 commit（已在 .gitignore）

# 国内数据源
WIND_API_TOKEN=
CHOICE_API_TOKEN=

# 国际数据源
FACTSET_API_KEY=
BLOOMBERG_API_KEY=

# 自有数据库
INTERNAL_DB_URL=
INTERNAL_DB_USER=
INTERNAL_DB_PASSWORD=

# 公开数据（一般无凭证）
# CSRC_PUBLIC=    # 证监会公开
# PBOC_PUBLIC=    # 央行公开
# NBS_PUBLIC=     # 统计局公开

# 中心化审计日志（可选，Ch27 模式 A）
AUDIT_LOG_ENDPOINT=
AUDIT_LOG_TOKEN=
